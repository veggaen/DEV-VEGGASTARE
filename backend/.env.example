# Backend Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
WS_PORT=3002
NODE_ENV=development  # Set to "production" on Railway

# CORS (comma-separated origins, required in production)
# CORS_ORIGINS=https://www.veggat.com,https://veggat.com

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DATABASE_URL_NEON="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"

# Pusher (real-time updates)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu

# Bring Shipping API
BRING_API_UID=
BRING_API_KEY=
BRING_CUSTOMER_NUMBER=
BRING_MODE=mock  # "mock" for testing, "live" for production
