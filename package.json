{
  "name": "veggastare",
  "version": "1.0.0",
  "private": true,
  "description": "VeggaStare monorepo – frontend (Next.js / Vercel) + backend (Hapi / Railway)",
  "scripts": {
    "start": "npm run start:project",
    "stop": "npm run stop:project",
    "restart": "npm run restart:project",
    "dev": "concurrently -n FE,BE -c cyan,yellow \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev:fe": "npm run dev --prefix frontend",
    "dev:be": "npm run dev --prefix backend",
    "start:project": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-start.ps1",
    "stop:project": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-stop.ps1",
    "restart:project": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-restart.ps1",
    "build:fe": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "prisma:generate": "npx --prefix frontend prisma generate",
    "prisma:studio": "npx --prefix frontend prisma studio",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
