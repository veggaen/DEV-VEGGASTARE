// datasource & generator
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

enum EmployeeRole {
  OWNER
  MANAGER
  STAFF
  USER
}

enum PackageStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

// Conversation type determines the nature of the conversation
enum ConversationType {
  PUBLIC_THREAD    // Open forum-style thread, anyone can view
  PRIVATE_DM       // Direct message between 2 users
  GROUP            // Private group chat with invited participants
  RESTRICTED       // Visible to specific roles or custom list
}

// Who can see/read the conversation
enum ConversationVisibility {
  PUBLIC           // Anyone can read
  PARTICIPANTS     // Only participants can read
  ROLE_BASED       // Only users with specific roles can read
  CUSTOM           // Custom list of allowed viewers
}

// Who can reply/post messages
enum ReplyPermission {
  EVERYONE         // Anyone who can view can reply
  PARTICIPANTS     // Only participants can reply
  MENTIONED        // Only mentioned users can reply
  MODS_ONLY        // Only moderators/admins can reply
  CREATOR_ONLY     // Only the creator can post (announcement mode)
}

// Deletion visibility - how the pending deletion is shown
enum DeletionVisibility {
  PUBLIC           // Shows "This thread is being deleted in X days"
  PRIVATE          // Silent deletion, no public notice
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  METAMASK
  PAYPAL
  COINBASEWALLET
  VISA
  SOLFLARE
  PHANTOM
  MATHWALLET
  TRUST
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

// NEW: which chain family a wallet/token belongs to
enum ChainFamily {
  EVM
  SOLANA
}

// Company legal form (Norway-inspired)
enum CompanyOrgType {
  ENK
  AS
  ANS
  DA
  SA
  FORENING
  NUF
  OTHER
}

enum TerminationStatus {
  REQUESTED
  CANCELLED
  FINALIZED
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  referredBy            String?
  role                  UserRole               @default(USER)

  // Versioned site notice dismissal (e.g. "Under development" banner)
  siteNoticeDismissedVersion Int               @default(0)

  // NEW: default Web2 UX, opt-in Web3 features
  web3ModeEnabled       Boolean                @default(false)

  accounts              Account[]
  productsListed        Product[]              @relation("ProductsListed")
  reviews               Review[]
  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  createdCompanies      Company[]              @relation("Creator")
  ownedCompanies        Company[]              @relation("Owner")
  Employee              Employee[]
  Package               Package[]
  warehouseLocations    WarehouseLocation[]    @relation("UserWarehouses")
  carts                 Cart[]
  orders                Order[]
  jobRequests           JobRequest[]
  messages              Message[]              @relation("UserMessages")
  createdConversations  Conversation[]         @relation("CreatedConversations")
  conversationViews     ConversationView[]     @relation("UserConversationViews")
  conversationReposts   ConversationRepost[]   @relation("UserConversationReposts")

  // NEW: user-scoped wallets
  wallets               Wallet[]               @relation("UserWallets")

  // NEW: security-sensitive action confirmations (e.g. enable/disable Web3 mode)
  securityActionTokens  SecurityActionToken[]

  // NEW: wallet-ownership verification challenges
  walletVerificationChallenges WalletVerificationChallenge[]

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  terminationRequestsInitiated EmployeeTermination[] @relation("TerminationInitiator")
  terminationsAsEmployee       EmployeeTermination[] @relation("TerminatedEmployee")
}

enum SecurityActionType {
  WEB3_MODE_ENABLE
  WEB3_MODE_DISABLE
}

model SecurityActionToken {
  id        String             @id @default(cuid())
  userId    String
  email     String
  token     String             @unique
  action    SecurityActionType
  expires   DateTime
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, action])
  @@index([userId, action])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

// ───────────────────────────────────────────────────────────────────────────────
// PRODUCTS RELATED
// ───────────────────────────────────────────────────────────────────────────────

model Product {
  id               String            @id @default(cuid())
  title            String
  description      String
  category         String
  price            Float
  stock            Int
  shipFromPostalId String
  image            String[]
  specifications   Json?
  userId           String
  user             User              @relation("ProductsListed", fields: [userId], references: [id])
  companyId        String?
  company          Company?          @relation("CompanyProducts", fields: [companyId], references: [id])
  inventory        Inventory[]
  shippingDetails  ShippingDetails[]
  reviews          Review[]
  cartItems        CartItem[]

  // NEW: where payments for this product should be received
  receiverWalletId String?
  receiverWallet   Wallet?           @relation("ProductReceiverWallet", fields: [receiverWalletId], references: [id])

  // NEW: optional token allowlist for this product
  acceptedTokens   ProductAcceptedToken[]

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Inventory {
  id          String            @id @default(cuid())
  quantity    Int
  stock       Int               @default(0)
  warehouseId String
  productId   String
  warehouse   WarehouseLocation @relation(fields: [warehouseId], references: [id])
  product     Product           @relation(fields: [productId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  version     Int               @default(0)

  @@unique([id, version])
}

model SpecificationsDetails {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingDetails {
  id        String   @id @default(cuid())
  method    String
  price     Float
  regions   String[]
  productId String
  product   Product? @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id         String   @id @default(cuid())
  authorName String?
  rating     Float
  comment    String
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ───────────────────────────────────────────────────────────────────────────────
// Company Related
// ───────────────────────────────────────────────────────────────────────────────

model Company {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  websiteUrl         String?
  logo               String[]
  bannerImage        String[]
  colorScheme        String?

  // Registration / legal metadata
  orgType             CompanyOrgType?
  orgNumber           String?             @unique
  // App policy defaults (not legal advice): used for UX/warnings
  employmentNoticeDays Int               @default(14)

  creatorId          String
  ownerId            String
  creator            User                @relation("Creator", fields: [creatorId], references: [id])
  owner              User                @relation("Owner", fields: [ownerId], references: [id])
  employees          Employee[]
  terminations       EmployeeTermination[]
  usesShipping       Boolean             @default(false)
  warehouseLocations WarehouseLocation[] @relation("CompanyWarehouses")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Sale               Sale[]
  MonthlyReport      MonthlyReport[]
  Package            Package[]
  Product            Product[]           @relation("CompanyProducts")
  conversations      Conversation[]      @relation("CompanyConversations")

  // NEW: company-scoped wallets
  wallets            Wallet[]            @relation("CompanyWallets")
}

model EmployeeTermination {
  id              String            @id @default(cuid())
  companyId        String
  employeeUserId   String
  initiatedByUserId String

  status          TerminationStatus @default(REQUESTED)
  reason          String
  noticeDays      Int
  requestedAt     DateTime          @default(now())
  effectiveAt     DateTime
  cancelledAt     DateTime?
  finalizedAt     DateTime?
  metadata        Json?

  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        User              @relation("TerminatedEmployee", fields: [employeeUserId], references: [id], onDelete: Cascade)
  initiatedBy     User              @relation("TerminationInitiator", fields: [initiatedByUserId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeUserId])
  @@index([companyId, status])
}

model Employee {
  id          String       @id @default(cuid())
  userId      String
  companyId   String
  user        User         @relation(fields: [userId], references: [id])
  company     Company      @relation(fields: [companyId], references: [id])
  role        EmployeeRole
  jobTitle    String?
  permissions Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Where stock is located
model WarehouseLocation {
  id         String      @id @default(cuid())
  userId     String?
  companyId  String?
  postalCode String
  address    String
  city       String
  country    String
  latitude   Float?
  longitude  Float?
  inventory  Inventory[]

  user    User?    @relation("UserWarehouses", fields: [userId], references: [id])
  company Company? @relation("CompanyWarehouses", fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, postalCode])
}

// ───────────────────────────────────────────────────────────────────────────────
// NEW: Wallets and accepted tokens
// ───────────────────────────────────────────────────────────────────────────────

model Wallet {
  id              String      @id @default(cuid())
  label           String
  family          ChainFamily
  // EVM specifics
  chainId         Int?
  // Solana specifics
  solanaCluster   String?
  address         String
  isDefault       Boolean     @default(false)

  // When linked via a signed challenge, mark verification timestamp.
  verifiedAt      DateTime?

  // ownership (one of these is set)
  ownerUserId     String?
  ownerCompanyId  String?

  user            User?       @relation("UserWallets", fields: [ownerUserId], references: [id])
  company         Company?    @relation("CompanyWallets", fields: [ownerCompanyId], references: [id])

  // products that pay to this wallet
  products        Product[]   @relation("ProductReceiverWallet")

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model WalletVerificationChallenge {
  id            String      @id @default(cuid())
  userId        String
  family        ChainFamily
  address       String
  chainId       Int?
  solanaCluster String?
  nonce         String
  message       String      @db.Text
  expires       DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, family, address])
  @@index([expires])
}

model ProductAcceptedToken {
  id           String      @id @default(cuid())
  productId    String
  product      Product     @relation(fields: [productId], references: [id])

  family       ChainFamily
  tokenAddress String?     // EVM/PRC20
  tokenMint    String?     // SPL
  symbol       String
  decimals     Int

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([productId, family, symbol])
}

// ───────────────────────────────────────────────────────────────────────────────
// Analytics / Shipping / Cart / Orders / Chat
// ───────────────────────────────────────────────────────────────────────────────

model Sale {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  date         DateTime
  totalAmount  Float
  profit       Float
  productsSold Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MonthlyReport {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id])
  year           Int
  month          Int
  totalSales     Float
  totalProfit    Float
  productSummary Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Package {
  id                String        @id @default(cuid())
  trackingNumber    String
  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])
  userId            String
  user              User          @relation(fields: [userId], references: [id])
  status            PackageStatus
  estimatedDelivery DateTime?
  history           Json
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, cartId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  totalAmount     Float
  status          OrderStatus @default(PENDING)
  commentOrder    String?
  payment         Payment?
  transactionId   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  order           Order         @relation(fields: [orderId], references: [id])
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  commentPay      String?
  transactionId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model JobRequest {
  id              String   @id @default(cuid())
  title           String?
  descriptions    String[]
  images          String[]
  links           String[]
  docs            String[]
  price           Float?
  negotiable      Boolean?
  paymentMethod   String?
  delivery        String?
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  email           String
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyIds      String[] @default([])
}

// Messaging Models
model Conversation {
  id               String                  @id @default(cuid())
  title            String?
  description      String?                 // Optional description for public threads
  userId           String                  // Creator
  user             User                    @relation("CreatedConversations", fields: [userId], references: [id])
  participants     String[]                // Array of user IDs (kept for backwards compatibility)
  companyId        String?
  company          Company?                @relation("CompanyConversations", fields: [companyId], references: [id])
  messages         Message[]               @relation("ConversationMessages")

  // Reposts
  // - Simple repost: join table (no added text)
  // - Quote repost: a new Conversation that references the original via repostOfConversationId
  reposts           ConversationRepost[]      @relation("ConversationReposts")
  repostOfConversationId String?
  repostOfConversation   Conversation?        @relation("ConversationQuoteReposts", fields: [repostOfConversationId], references: [id], onDelete: SetNull)
  quoteReposts           Conversation[]       @relation("ConversationQuoteReposts")

  // New fields for visibility and permissions
  type             ConversationType        @default(PRIVATE_DM)
  visibility       ConversationVisibility  @default(PARTICIPANTS)
  replyPermission  ReplyPermission         @default(PARTICIPANTS)

  // Optional: allowed roles for ROLE_BASED visibility (stored as JSON array of role strings)
  allowedRoles     String[]                @default([])

  // Optional: custom viewer list for CUSTOM visibility (user IDs)
  customViewers    String[]                @default([])

  // Moderation
  isPinned         Boolean                 @default(false)
  isLocked         Boolean                 @default(false)  // No new replies allowed

  // Topics/Tags for forum browsing
  tags             String[]                @default([])

  // Engagement metrics (for "reach over followers" sorting)
  // These track actual engagement, not vanity metrics
  viewCount        Int                     @default(0)      // Total page loads/views
  uniqueViewCount  Int                     @default(0)      // Unique users who viewed
  replyCount       Int                     @default(0)      // Total replies (cached for performance)
  uniqueRepliers   Int                     @default(0)      // Unique users who replied
  lastActivityAt   DateTime                @default(now())  // Last message or interaction
  views            ConversationView[]      @relation("ConversationViews")

  // Deletion system (tiered based on reach)
  deletionRequestedAt  DateTime?                            // When creator requested deletion
  deletionScheduledFor DateTime?                            // When it will actually be deleted
  deletionVisibility   DeletionVisibility  @default(PRIVATE) // Public notice or silent deletion
  isAnonymized         Boolean             @default(false)  // Creator anonymized immediately on delete request
  originalUserId       String?                              // Store original creator ID when anonymized

  // Suspicious activity detection (for viral velocity checks)
  suspiciousActivity   Boolean             @default(false)  // Flagged for admin review
  suspiciousReason     String?                              // Why it was flagged

  // Poll attached to conversation (optional)
  poll             Poll?                   @relation("ConversationPoll")

  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model ConversationRepost {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation("ConversationReposts", fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("UserConversationReposts", fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

// Track unique views per user for conversations
model ConversationView {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation("ConversationViews", fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String        // Who viewed (null for anonymous - but we only track logged-in users)
  user           User          @relation("UserConversationViews", fields: [userId], references: [id], onDelete: Cascade)
  viewCount      Int           @default(1)  // How many times this user viewed
  firstViewedAt  DateTime      @default(now())
  lastViewedAt   DateTime      @default(now())

  @@unique([conversationId, userId])  // One record per user per conversation
  @@index([conversationId])
  @@index([userId])
}

// Poll for conversations - allows voting within a thread
model Poll {
  id               String        @id @default(cuid())
  question         String        // The poll question
  conversationId   String        @unique
  conversation     Conversation  @relation("ConversationPoll", fields: [conversationId], references: [id], onDelete: Cascade)
  creatorId        String        // Who created the poll

  // Poll configuration
  allowMultiple    Boolean       @default(false)  // Can vote for multiple options
  isAnonymous      Boolean       @default(false)  // Hide who voted for what
  expiresAt        DateTime?                      // When voting closes (null = never)

  // Poll options and votes (stored as relations)
  options          PollOption[]  @relation("PollOptions")

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// Poll option - each choice in a poll
model PollOption {
  id        String      @id @default(cuid())
  pollId    String
  poll      Poll        @relation("PollOptions", fields: [pollId], references: [id], onDelete: Cascade)
  text      String      // The option text
  order     Int         @default(0)  // Display order

  // Votes for this option
  votes     PollVote[]  @relation("OptionVotes")

  createdAt DateTime    @default(now())
}

// Poll vote - tracks who voted for what
model PollVote {
  id        String      @id @default(cuid())
  optionId  String
  option    PollOption  @relation("OptionVotes", fields: [optionId], references: [id], onDelete: Cascade)
  userId    String

  createdAt DateTime    @default(now())

  // Ensure one vote per user per option
  @@unique([optionId, userId])
}

model Message {
  id             String        @id @default(cuid())
  content        String
  senderId       String
  sender         User          @relation("UserMessages", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation  @relation("ConversationMessages", fields: [conversationId], references: [id], onDelete: Cascade)
  imageUrl       String?

  // Mentions: array of user IDs mentioned in this message
  mentions       String[]      @default([])

  // Optional: parent message ID for threaded replies
  parentId       String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  editedAt       DateTime?
}
