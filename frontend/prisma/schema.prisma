// ─────────────────────────────────────────────────
// P2P Crypto Trade System
// ─────────────────────────────────────────────────

model Trade {
  id             String           @id @default(cuid())
  initiatorId    String           // user who sent the trade request
  responderId    String           // user who received the trade request
  chainId        Int?             // chain this trade is on (null = multi-chain)
  family         ChainFamily      @default(EVM)
  status         TradeStatus      @default(PENDING)
  environment    TradeEnvironment @default(MAINNET)  // paper, testnet, or mainnet
  initiatorReady Boolean          @default(false)
  responderReady Boolean          @default(false)
  // Both must set ready=true, then status moves to CONFIRMING
  // After on-chain or off-chain settlement, status moves to COMPLETED
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  expiresAt      DateTime    // auto-cancel if not accepted within time
  metadata       Json?       // extra trade context
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  Initiator      User        @relation("TradesInitiated", fields: [initiatorId], references: [id])
  Responder      User        @relation("TradesReceived", fields: [responderId], references: [id])
  Items          TradeItem[]

  @@index([initiatorId, status])
  @@index([responderId, status])
  @@index([expiresAt])
}

model TradeItem {
  id             String      @id @default(cuid())
  tradeId        String
  side           TradeSide   // INITIATOR or RESPONDER — who is offering this
  tokenAddress   String      // ERC-20 contract address (or "0x0" for native ETH)
  tokenSymbol    String      // e.g. "ETH", "USDC", "HEX"
  tokenDecimals  Int         @default(18)
  tokenLogoUrl   String?
  amount         String      // BigInt string — raw wei/smallest unit
  displayAmount  String      // human-readable e.g. "1.5"
  chainId        Int
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  Trade          Trade       @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  @@index([tradeId, side])
}

enum TradeStatus {
  PENDING     // request sent, awaiting acceptance
  ACCEPTED    // responder joined, both can add items
  CONFIRMING  // both ready, awaiting final confirm
  COMPLETED   // trade settled
  CANCELLED   // cancelled by either party
  EXPIRED     // auto-expired
}

enum TradeSide {
  INITIATOR
  RESPONDER
}

enum TradeEnvironment {
  MAINNET  // Real chain, real money
  TESTNET  // Sepolia etc., faucet tokens
  PAPER    // Simulated — no chain interaction, DB-only
}

// ─────────────────────────────────────────────────────────────────────────────
// TRADE RECORDS — Unified execution log across ALL trading modes
// ─────────────────────────────────────────────────────────────────────────────

/// Unified trade execution record — tracks ALL completed/pending trades across
/// modes (P2P, Self, DEX, Paper, LocalChain). Single source of truth for trade
/// history, tax reporting, and analytics. Follows OWASP data integrity principles:
/// all monetary fields are strings to avoid floating-point precision errors.
model TradeRecord {
  id               String           @id @default(cuid())
  userId           String
  mode             TradeMode

  // ── What was traded ──────────────────────────────────────────────────────
  sellToken        String           // "ETH", "USDC", "PLS", etc.
  sellTokenAddress String           // Contract address or "0x0000000000000000000000000000000000000000" for native
  sellAmount       String           // BigInt string (raw, smallest unit), avoids float precision loss
  sellDisplayAmt   String           // Human-readable e.g. "1.5"
  sellDecimals     Int              @default(18)
  sellChainId      Int

  buyToken         String
  buyTokenAddress  String
  buyAmount        String
  buyDisplayAmt    String
  buyDecimals      Int              @default(18)
  buyChainId       Int

  // ── Price data (ISO 4217 + crypto) ────────────────────────────────────────
  priceUsd         Float?           // USD value of the trade at execution
  priceNok         Float?           // NOK value at execution (Norwegian tax)
  feeUsd           Float?           // Trading fee in USD
  feeNok           Float?           // Trading fee in NOK
  exchangeRate     Float?           // sell/buy price ratio at execution time
  priceSource      String?          // "coingecko" | "kyberswap" | "manual" | "paper"

  // ── Context ──────────────────────────────────────────────────────────────
  tradeId          String?          // FK to Trade (if P2P)
  paperTradeId     String?          // FK to PaperTrade (if paper)
  txHash           String?          // On-chain transaction hash (if real)
  blockNumber      Int?             // Block the tx was confirmed in
  walletAddress    String?          // Wallet that initiated the trade
  walletId         String?          // FK to Wallet (if linked)
  counterpartyId   String?          // Other user ID (if P2P)
  counterpartyAddr String?          // Other user wallet address
  environment      TradeEnvironment @default(MAINNET)
  status           TradeRecordStatus @default(COMPLETED)
  failReason       String?          // If status = FAILED

  // ── Norwegian Tax Helper (Skatteetaten-compatible) ────────────────────────
  /// FIFO cost basis tracking — what the sold asset originally cost to acquire
  costBasisUsd     Float?
  costBasisNok     Float?
  /// Realized profit/loss (= proceeds − cost basis − fees)
  gainLossUsd      Float?
  gainLossNok      Float?
  /// How long the asset was held before disposal (for formueskatt reporting)
  holdingDays      Int?
  /// Tax year for grouping in annual reports
  taxYear          Int?
  /// Whether this record has been included in a tax export
  taxExported      Boolean          @default(false)
  taxExportedAt    DateTime?

  // ── Ownership ─────────────────────────────────────────────────────────────
  companyId        String?          // null = personal trade, set = company trade
  metadata         Json?            // Extra context (route info, slippage, DEX aggregator data)

  executedAt       DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  User             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Company          Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([userId, executedAt])
  @@index([userId, mode])
  @@index([userId, taxYear])
  @@index([companyId, executedAt])
  @@index([txHash])
  @@index([walletAddress])
  @@index([status])
}

enum TradeMode {
  P2P        // Peer-to-peer trade
  SELF       // Internal transfer between own wallets
  DEX        // DEX swap (KyberSwap, Uniswap, etc.)
  PAPER      // Simulated paper trade
  LOCAL      // Local chain (Anvil/Ganache) trade
}

enum TradeRecordStatus {
  PENDING    // Trade submitted, awaiting on-chain confirmation
  COMPLETED  // Successfully executed
  FAILED     // Failed on-chain or cancelled
  REVERTED   // On-chain revert
}

/// Cost basis calculation method for tax reporting.
/// Norway's Skatteetaten accepts both FIFO and average cost.
enum CostBasisMethod {
  FIFO       // First In, First Out — standard Norwegian method
  AVERAGE    // Weighted average cost — also accepted by Skatteetaten
}

// ─────────────────────────────────────────────────────────────────────────────
// AI POLL SYSTEM — Quota, Search Budget, Scheduled Polls
// ─────────────────────────────────────────────────────────────────────────────

enum ReviewStatus {
  PENDING_REVIEW // AI-generated or scheduled — awaiting owner approval
  APPROVED       // Verified by human — visible in feed
  REJECTED       // Rejected by owner — hidden from feed
}

/// Tracks daily AI generation usage per user (replaces volatile in-memory Map).
/// One row per user per day. Survives Vercel cold starts.
model DailyAiUsage {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

/// Scheduled poll templates for automated cron-based poll generation.
model ScheduledPoll {
  id               String    @id @default(cuid())
  cronExpression   String    // Cron format e.g. "0 9 * * *" (9 AM daily)
  promptTemplate   String    // Prompt sent to AI for generation
  targetFeedId     String?   // Optional: post to specific conversation/feed
  isActive         Boolean   @default(true)
  autoPublish      Boolean   @default(true)
  lastRunAt        DateTime?
  nextRunAt        DateTime?
  createdBy        String
  Creator          User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([isActive])
  @@index([nextRunAt])
  @@index([createdBy])
}

// ─── GDPR / DSA Compliance Models ──────────────────────────────────────────────

/// DSA-compliant content report submitted by a user.
model ContentReport {
  id               String              @id @default(cuid())
  reporterId       String              // The user who filed the report
  contentType      ReportContentType   // What kind of content is being reported
  contentId        String              // The ID of the reported content (post, message, product, etc.)
  reason           ReportReason        // Categorised reason for the report
  description      String?             // Optional free-text description
  status           ReportStatus        @default(PENDING)
  reviewedById     String?             // Admin who reviewed the report
  resolutionNote   String?             // Explanation of the resolution
  resolvedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  Reporter         User                @relation("ContentReports", fields: [reporterId], references: [id], onDelete: Cascade)
  ReviewedBy       User?               @relation("ContentReportReviews", fields: [reviewedById], references: [id], onDelete: SetNull)
  ModerationAction ModerationAction?
  Appeals          ContentAppeal[]

  @@index([reporterId])
  @@index([contentType, contentId])
  @@index([status])
  @@index([createdAt])
}

enum ReportContentType {
  POST          // Pulse post / Conversation
  MESSAGE       // DM or group message
  PRODUCT       // Product listing
  POLL          // Poll / Quiz
  USER_PROFILE  // User profile (name, bio, avatar)
  IMAGE         // Uploaded image
  OTHER
}

enum ReportReason {
  ILLEGAL_CONTENT
  HATE_SPEECH
  HARASSMENT
  VIOLENCE
  SEXUAL_CONTENT
  CHILD_EXPLOITATION
  SPAM
  SCAM
  IMPERSONATION
  COPYRIGHT_INFRINGEMENT
  MISINFORMATION
  PLATFORM_MANIPULATION
  OTHER
}

enum ReportStatus {
  PENDING       // Awaiting review
  IN_REVIEW     // Assigned to a moderator
  RESOLVED      // Action taken (removed, warned, or dismissed)
  DISMISSED     // Report dismissed as invalid
}

/// Tracks moderation decisions for DSA transparency and appeals (Art. 17).
model ModerationAction {
  id              String               @id @default(cuid())
  reportId        String               @unique
  action          ModerationActionType
  reason          String               // Statement of reasons (DSA Art. 17)
  targetUserId    String?              // User whose content was moderated
  createdAt       DateTime             @default(now())
  Report          ContentReport        @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([targetUserId])
  @@index([createdAt])
}

enum ModerationActionType {
  CONTENT_REMOVED
  CONTENT_RESTRICTED    // Hidden from public but not deleted
  ACCOUNT_WARNING
  ACCOUNT_SUSPENDED
  ACCOUNT_BANNED
  DISMISSED             // No action taken
  REFERRED_TO_AUTHORITY // Reported to police/NCMEC
}

/// User appeal of a moderation decision (DSA Art. 20).
model ContentAppeal {
  id              String        @id @default(cuid())
  reportId        String
  appellantId     String        // The user appealing
  reason          String        // Why the user disagrees
  status          AppealStatus  @default(PENDING)
  reviewedById    String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  Report          ContentReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  Appellant       User          @relation("ContentAppeals", fields: [appellantId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([appellantId])
  @@index([status])
}

enum AppealStatus {
  PENDING
  UPHELD      // Original decision stands
  OVERTURNED  // Decision reversed
}

/// GDPR data export request (Art. 15 / Art. 20).
model DataExportRequest {
  id          String              @id @default(cuid())
  userId      String
  status      DataRequestStatus   @default(PENDING)
  downloadUrl String?             // Signed URL to the export file (expires)
  expiresAt   DateTime?           // When the download link expires
  completedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  User        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

/// GDPR account deletion request (Art. 17 — right to erasure).
model AccountDeletionRequest {
  id            String              @id @default(cuid())
  userId        String
  status        DataRequestStatus   @default(PENDING)
  reason        String?             // Optional user-provided reason
  scheduledFor  DateTime            // Deletion scheduled 30 days from request
  cancelledAt   DateTime?           // If user cancelled the request
  completedAt   DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  User          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
}

enum DataRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  FAILED
}

/// Reason for return/refund request
enum ReturnReason {
  CHANGED_MIND         // Buyer changed mind (Angrerettloven 14-day right)
  DEFECTIVE            // Product is defective or damaged
  WRONG_ITEM           // Received wrong item
  NOT_AS_DESCRIBED     // Product doesn't match listing
  LATE_DELIVERY        // Delivery significantly delayed
  OTHER                // Free-text reason
}

/// Status of a return/refund request
enum ReturnRequestStatus {
  PENDING              // Buyer submitted, awaiting seller review
  APPROVED             // Seller approved return
  REJECTED             // Seller rejected (with reason)
  REFUNDED             // Refund processed
  COMPLETED            // Return fully processed (item received back if physical)
  CANCELLED            // Buyer or seller cancelled the request
}

// ─── AI Chat System ─────────────────────────────────────────────────────────

enum AiParticipantType {
  HUMAN
  AI_PLATFORM
  AI_BYOK
}

// Per-conversation membership role (Discord-style). The creator is OWNER;
// OWNER/MODERATOR may manage members; MEMBER is a regular participant.
enum AiMemberRole {
  OWNER
  MODERATOR
  MEMBER
}

enum AiTriggerMode {
  MENTION
  DEBOUNCE
  ALL
  MANUAL
}

enum AiResponseMode {
  CONTEXT_ONLY
  DEEP_ANALYSIS
}

model AiConversation {
  id                String              @id @default(cuid())
  title             String              @default("New Chat")
  creatorId         String
  creator           User                @relation("AiConversationCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  shareToken        String?             @unique
  isPublic          Boolean             @default(false)
  pulseId           String?

  // Moderation fields
  isSuspended       Boolean             @default(false)
  suspendedReason   String?
  suspendedAt       DateTime?
  suspendedBy       String?
  isDeleted         Boolean             @default(false)
  deletedAt         DateTime?
  deletedBy         String?

  // Per-conversation AI trigger settings
  triggerMode       AiTriggerMode       @default(MENTION)
  debounceMs        Int                 @default(3000)
  allTriggerEnabled Boolean             @default(false)
  heartbeatEnabled  Boolean             @default(true)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  participants      AiConvParticipant[]
  messages          AiConvMessage[]

  @@index([creatorId, createdAt(sort: Desc)])
  @@index([isPublic, createdAt(sort: Desc)])
}

model AiConvParticipant {
  id              String              @id @default(cuid())
  conversationId  String
  conversation    AiConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  type            AiParticipantType
  userId          String?
  user            User?               @relation("AiConvHumanParticipant", fields: [userId], references: [id], onDelete: SetNull)

  // Discord-style membership role. Defaults to MEMBER; the creator is promoted
  // to OWNER. Governs who can manage members (add/remove/promote).
  role            AiMemberRole        @default(MEMBER)

  // AI participant config (null for HUMAN type)
  displayName     String?
  aiProvider      String?
  aiModel         String?
  byokUserId      String?
  isActive        Boolean             @default(true)
  heartbeatEnabled Boolean            @default(true)

  // BYOK AI response settings (controlled by the human who owns this AI)
  responseMode    AiResponseMode      @default(CONTEXT_ONLY)
  responseBrief   Boolean             @default(false)
  manualOnly      Boolean             @default(false)

  createdAt       DateTime            @default(now())
  messages        AiConvMessage[]
  reactions       AiConvReaction[]

  // NOTE: In PostgreSQL, NULL != NULL in unique constraints, so multiple AI
  // participants (userId=null) are allowed. Human uniqueness enforced in app layer.
  @@unique([conversationId, userId])
  @@index([conversationId])
}

model AiConvMessage {
  id              String              @id @default(cuid())
  conversationId  String
  conversation    AiConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  participantId   String
  participant     AiConvParticipant   @relation(fields: [participantId], references: [id])

  content         String              @db.Text
  role            String              // "user" | "assistant"
  senderType      AiParticipantType

  // AI metadata (null for human messages)
  modelUsed       String?
  providerUsed    String?
  tokenCount      Int?

  // Sensitive data flags
  hasSensitiveData Boolean            @default(false)
  sensitiveTypes  String[]

  createdAt       DateTime            @default(now())
  reactions       AiConvReaction[]

  @@index([conversationId, createdAt])
}

model AiConvReaction {
  id              String              @id @default(cuid())
  messageId       String
  message         AiConvMessage       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  participantId   String
  participant     AiConvParticipant   @relation(fields: [participantId], references: [id])
  type            String              // "POSITIVE" | "NEGATIVE" | "HEARTBEAT"
  createdAt       DateTime            @default(now())

  @@unique([messageId, participantId, type])
}

model AiConvAuditLog {
  id              String    @id @default(cuid())
  conversationId  String?
  actorId         String?
  targetUserId    String?
  action          String    // SUSPEND | UNSUSPEND | DELETE | ADMIN_VIEW | FLAG | INJECTION_BLOCKED | RATE_LIMIT_HIT
  reason          String?
  metadata        Json?
  ipAddress       String?
  createdAt       DateTime  @default(now())

  @@index([conversationId])
  @@index([actorId])
  @@index([action, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAPER TRADING SYSTEM — Virtual portfolio + simulated trades
// ─────────────────────────────────────────────────────────────────────────────

/// Virtual portfolio for paper trading (one per user).
/// Tracks paper USD cash balance and token positions using real market prices.
model PaperPortfolio {
  id              String           @id @default(cuid())
  userId          String           @unique
  /// Starting virtual USD balance (user-configurable with min/max limits)
  startingBalance Float            @default(100000)
  /// Remaining virtual USD available to spend
  cashBalance     Float            @default(100000)
  /// How many times the user has reset their portfolio
  resetCount      Int              @default(0)
  lastResetAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  User            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  Positions       PaperPosition[]
  Trades          PaperTrade[]

  @@index([userId])
}

/// Individual token position in a paper portfolio.
/// Each unique (token, chain) combination gets one row; amounts are cumulative.
model PaperPosition {
  id              String          @id @default(cuid())
  portfolioId     String
  tokenSymbol     String          // "ETH", "USDC", etc.
  tokenAddress    String          // contract address or "0x0" for native
  chainId         Int             // which chain this token "lives on"
  decimals        Int             @default(18)
  /// Raw amount as BigInt string (smallest unit, e.g. wei)
  amount          String          @default("0")
  /// Human-readable display amount (e.g. "2.5")
  displayAmount   String          @default("0")
  /// Weighted average USD entry price across all buys
  avgEntryPrice   Float           @default(0)
  /// Total USD cost of all buys for this position (for P&L calc)
  totalCostBasis  Float           @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  Portfolio       PaperPortfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, tokenSymbol, chainId])
  @@index([portfolioId])
}

/// Record of a single paper trade execution.
/// Every buy, sell, swap, or P2P paper transfer is recorded here.
model PaperTrade {
  id              String          @id @default(cuid())
  portfolioId     String
  type            PaperTradeType
  // ── Sell side ──
  sellToken       String?         // token sold (or "USD" for paper cash)
  sellAmount      String?         // raw amount string
  sellDisplayAmt  String?         // human-readable
  sellPriceUsd    Float?          // USD price per unit at execution
  // ── Buy side ──
  buyToken        String?         // token bought (or "USD" for paper cash)
  buyAmount       String?         // raw amount string
  buyDisplayAmt   String?         // human-readable
  buyPriceUsd     Float?          // USD price per unit at execution
  // ── Metadata ──
  chainId         Int?
  feeUsd          Float?          // simulated trading fee in USD
  priceSource     String?         // "coingecko" | "zerox" | "manual"
  metadata        Json?           // route info, slippage, etc.
  executedAt      DateTime        @default(now())

  Portfolio       PaperPortfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, executedAt])
  @@index([portfolioId, type])
}

enum PaperTradeType {
  BUY           // buy token with paper USD
  SELL          // sell token for paper USD
  SWAP          // token-to-token swap (via DEX quote)
  P2P_SEND      // sent to another user in paper P2P trade
  P2P_RECEIVE   // received from another user in paper P2P trade
  FAUCET        // initial token grant or reset
}

// ─────────────────────────────────────────────────────────────────────────────
// VOICE CHANNELS + DICTATION + VOICE-LEARNING
// See docs/VOICE_AND_DICTATION_DESIGN.md. The UI binds to lib/voice/types.ts;
// these tables are the server-side source of truth for channel membership/roles
// (the LiveKit token route derives publish/admin rights from VoiceChannelMember,
// NOT from a client-claimed isHost), session transcripts, and the dictation
// learning loop.
// ─────────────────────────────────────────────────────────────────────────────

/// DB membership role (superset of the UI VoiceRole host|speaker|listener).
/// Mirrors the AiMemberRole convention. HOST = channel owner/admin;
/// MODERATOR = host-capable manager; SPEAKER = may publish audio; LISTENER = subscribe-only.
enum VoiceRoleDB {
  HOST
  MODERATOR
  SPEAKER
  LISTENER
}

/// Where a dictation utterance originated.
enum DictationSource {
  COMPOSER // typed-into chat composer via mic / hold-key
  ROOM     // captured from a live voice channel
}

/// Classification of a single word-level correction the user made to dictation.
enum CorrectionKind {
  TYPO                 // user's own slip; not an STT error
  MISHEARD             // STT heard the wrong word — the signal we learn from
  INTENTIONAL_REPHRASE // user changed their mind; not an error
  UNKNOWN              // not yet classified (awaiting the user's answer)
}

/// A voice channel. May be attached to an existing Conversation (DM/group) AND/OR
/// be a standalone personal channel auto-created on first join (isPersonal).
model VoiceChannel {
  id             String      @id @default(cuid())
  /// Stable lookup key = the namespaced room the UI joins (e.g. "vegga_<roomId>").
  /// Uniform across AI sessions, DM/group conversations, and personal channels;
  /// the token route + all host actions resolve a channel by this.
  roomKey        String      @unique
  conversationId String? // optional link to a Conversation (DM/group)
  ownerUserId    String
  name           String
  slug           String
  isPersonal     Boolean     @default(false) // auto-created "<Name>'s channel"
  isLocked       Boolean     @default(false) // listeners can't self-promote when locked
  maxSpeakers    Int?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  owner          User                 @relation("VoiceChannelOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members        VoiceChannelMember[]
  sessions       VoiceSession[]

  @@unique([ownerUserId, slug])
  @@index([conversationId])
  @@index([ownerUserId])
}

/// A user's membership + role within a voice channel. Source of truth for
/// publish/admin authorization.
model VoiceChannelMember {
  id          String      @id @default(cuid())
  channelId   String
  userId      String
  role        VoiceRoleDB @default(LISTENER)
  mutedByHost Boolean     @default(false)
  joinedAt    DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  channel     VoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User         @relation("VoiceChannelMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

/// A single voice session (a span the channel was live), used for transcripts and
/// optional recordings.
model VoiceSession {
  id               String       @id @default(cuid())
  channelId        String
  startedAt        DateTime     @default(now())
  endedAt          DateTime?
  recordingAssetId String? // EdgeStore key (consent-gated)
  transcriptJson   Json? // [{ userId, ts, text }]
  participantsJson Json? // snapshot of who was present

  channel          VoiceChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId, startedAt])
}

/// Per-user dictation personalization profile — the applied half of the learning
/// loop (custom vocabulary boosting + deterministic replacements).
model DictationProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  language         String   @default("en")
  customVocabulary String[] @default([]) // → Deepgram keyterm boosting
  replacements     Json     @default("{}") // { misheardForm: preferredForm } post-STT pass
  captureConsent   Boolean  @default(false) // store raw audio? opt-in
  utteranceCount   Int      @default(0)
  correctionCount  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation("DictationProfileOwner", fields: [userId], references: [id], onDelete: Cascade)
}

/// One accepted dictation result — the training corpus for the learning loop.
model DictationUtterance {
  id            String                @id @default(cuid())
  userId        String
  source        DictationSource       @default(COMPOSER)
  rawTranscript String                @db.Text
  finalText     String                @db.Text // what the user actually accepted/sent
  confidence    Float?
  wordsJson     Json? // per-word { word, start, end, confidence }
  audioAssetId  String? // EdgeStore key, only if captureConsent
  createdAt     DateTime              @default(now())

  user          User                  @relation("DictationUtteranceOwner", fields: [userId], references: [id], onDelete: Cascade)
  corrections   DictationCorrection[]

  @@index([userId, createdAt])
}

/// A single word-level correction the user made — the labeled signal.
model DictationCorrection {
  id                 String             @id @default(cuid())
  utteranceId        String
  originalWord       String
  correctedWord      String
  wordIndex          Int
  kind               CorrectionKind     @default(UNKNOWN)
  userConfirmed      Boolean            @default(false)
  reSaidAudioAssetId String?
  createdAt          DateTime           @default(now())

  utterance          DictationUtterance @relation(fields: [utteranceId], references: [id], onDelete: Cascade)

  @@index([utteranceId])
}