enum IdentityNameSource {
  AUTO
  MANUAL
  GOOGLE
  GITHUB
  DISCORD
}

enum IdentityImageSource {
  AUTO
  MANUAL
  GOOGLE
  GITHUB
  DISCORD
}

enum EmailDisplayMode {
  PRIMARY
  HIDE
}

model UserAiApiKey {
  id                String     @id @default(cuid())
  userId            String
  provider          AiProvider
  encryptedKey      String
  iv                String
  authTag           String
  keyFingerprint    String
  isDefault         Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  User              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([userId, isDefault])
}

enum AiProvider {
  OPENAI
  OPENROUTER
  ANTHROPIC
  GROK
  GROQ
  GOOGLE
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, token])
}

/// Token for verifying PayPal email ownership (Seller Payment Setup).
/// One token per entity (user or company) at a time.
model PaypalVerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  entityType String   // "user" | "company"
  entityId   String   // userId or companyId
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
}

model Wallet {
  id               String      @id @default(cuid())
  label            String
  family           ChainFamily
  chainId          Int?
  solanaCluster    String?
  address          String
  isDefault        Boolean     @default(false)
  ownerUserId      String?
  ownerCompanyId   String?
  /// Connector type that created this wallet (e.g. "AUTH", "injected", "walletConnect")
  connectorType    String?
  /// For AUTH wallets: the social provider (e.g. "google", "discord", "github")
  authProvider     String?
  /// For AUTH wallets: the email from the social provider
  socialEmail      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  verifiedAt       DateTime?
  donationTotalUsd Float       @default(0)
  riskTier         String?     // reach engine provenance: 'kyc' | 'neutral' | 'fresh'
  Product                        Product[]
  Donation                       Donation[]
  Company                        Company?    @relation(fields: [ownerCompanyId], references: [id])
  User                           User?       @relation(fields: [ownerUserId], references: [id])
  DefaultWalletForUsers           User[]      @relation("UserDefaultWallet")
  DefaultWalletForCompanies       Company[]   @relation("CompanyDefaultWallet")

  @@index([ownerUserId])
  @@index([ownerCompanyId])
}

/// On-chain donation records — used for buff tier progression.
/// Each row = one transaction to the system wallet.
model Donation {
  id            String   @id @default(cuid())
  userId        String
  walletId      String
  walletAddress String
  txHash        String   @unique
  nativeAmount  String   // "0.003" — original token amount
  amountUsd     Float    // USD value at time of donation
  chainFamily   String   // "EVM" | "SOLANA"
  chainId       Int?
  tokenSymbol   String   // "ETH", "SOL", "PLS", etc.
  status        String   @default("PENDING_CONFIRMATION") // PENDING_CONFIRMATION | CONFIRMED | FAILED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  User          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  Wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([walletId])
  @@index([txHash])
}

model WalletVerificationChallenge {
  id            String      @id @default(cuid())
  userId        String
  family        ChainFamily
  address       String
  chainId       Int?
  solanaCluster String?
  nonce         String
  message       String
  expires       DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  User          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expires])
  @@index([userId, family, address])
}

// Short-lived nonce for LOGGED-OUT wallet sign-in (SIWE-style). Unlike
// WalletVerificationChallenge (which links a wallet to an existing account and
// requires userId), this issues a challenge to any address so a visitor can
// authenticate / create an account with just their wallet.
model WalletLoginNonce {
  id        String   @id @default(cuid())
  address   String   // checksummed EVM address (lowercased for lookup)
  nonce     String
  message   String
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([address])
  @@index([expires])
}

model WarehouseLocation {
  id           String      @id @default(cuid())
  name         String?     // e.g. "Hovedlager Oslo"
  userId       String?
  companyId    String?
  postalCode   String
  address      String
  addressLine2 String?
  city         String
  country      String
  latitude     Float?
  longitude    Float?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Inventory    Inventory[]
  Company      Company?    @relation(fields: [companyId], references: [id])
  User         User?       @relation(fields: [userId], references: [id])

  @@unique([companyId, postalCode])
  @@index([userId])
}

// User saved addresses (home, work, etc.)
model Address {
  id           String       @id @default(cuid())
  userId       String
  label        AddressLabel @default(OTHER)
  customLabel  String?      // For "OTHER" type - user can name it
  addressLine1 String       // Street address + number
  addressLine2 String?      // Apartment, suite, unit, etc.
  postalCode   String
  city         String
  municipality String?
  county       String?
  country      String       @default("NO")
  latitude     Float?
  longitude    Float?
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  receiver   User                @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User                @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userA     User     @relation("FriendshipsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Pulse {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  type           PulseType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([type])
}

model PhoneVerification {
  id          String                    @id @default(cuid())
  userId      String
  phoneNumber String
  countryCode String
  provider    PhoneVerificationProvider @default(SVEVE)
  code        String?
  attempts    Int                       @default(0)
  status      PhoneVerificationStatus   @default(PENDING)
  expiresAt   DateTime
  verifiedAt  DateTime?
  lastSentAt  DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  User        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@index([status])
}

model UserPrivacySettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  showPulsesGiven     Boolean  @default(true)
  showPulsesReceived  Boolean  @default(true)
  showNegativePulses  Boolean  @default(false)
  showRepulses        Boolean  @default(true)
  allowNegativePulses Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id             String              @id @default(cuid())
  userId         String              // Recipient
  type           NotificationType
  title          String
  message        String
  emoji          String?
  preview        String?             // Short preview text
  imageUrl       String?             // Optional image thumbnail
  
  // Related entities
  actorId        String?             // User who triggered the notification
  conversationId String?             // Related pulse/conversation
  messageId      String?             // Related message
  
  // State
  isRead         Boolean             @default(false)
  isArchived     Boolean             @default(false)
  readAt         DateTime?
  
  // Grouping (for condensed notifications)
  groupKey       String?             // e.g., "heartbeat:conversationId" for grouping
  groupCount     Int                 @default(1)
  
  // Metadata
  metadata       Json?               // Extra data like { bpm: 100 } for hot pulse
  
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  expiresAt      DateTime?           // Optional expiry for ephemeral notifications
  
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([groupKey])
}

model NotificationSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  
  // Global settings
  pushEnabled             Boolean  @default(true)
  emailEnabled            Boolean  @default(false)
  soundEnabled            Boolean  @default(true)
  vibrateEnabled          Boolean  @default(true)
  
  // Quiet hours
  quietHoursEnabled       Boolean  @default(false)
  quietHoursStart         String?  // e.g., "22:00"
  quietHoursEnd           String?  // e.g., "08:00"
  quietHoursTimezone      String?  @default("UTC")
  
  // Category toggles (engagement)
  heartbeatEnabled        Boolean  @default(true)
  vibeEnabled             Boolean  @default(true)
  repulseEnabled          Boolean  @default(true)
  
  // Category toggles (social)
  syncEnabled             Boolean  @default(true)
  mentionEnabled          Boolean  @default(true)
  replyEnabled            Boolean  @default(true)
  
  // Category toggles (messages)
  dmEnabled               Boolean  @default(true)
  groupMessageEnabled     Boolean  @default(true)
  typingIndicatorEnabled  Boolean  @default(true)
  
  // Category toggles (trends)
  hotPulseEnabled         Boolean  @default(true)
  milestoneEnabled        Boolean  @default(true)
  
  // Category toggles (prompts)
  vibeCheckEnabled        Boolean  @default(false)
  dailyDigestEnabled      Boolean  @default(false)
  
  // Condensing settings
  condenseNotifications   Boolean  @default(true)
  condenseThreshold       Int      @default(3) // Group after X similar notifications
  
  // Premium features
  customSoundUrl          String?
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([userId])
}

model NotificationMute {
  id           String         @id @default(cuid())
  userId       String         // User who muted
  
  // What's being muted (one of these will be set)
