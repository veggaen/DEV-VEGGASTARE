generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  User      User       @relation(fields: [userId], references: [id])
  CartItem  CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Cart      Cart     @relation(fields: [cartId], references: [id])
  Product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, cartId])
  @@index([cartId])
}

model Company {
  id                           String                @id @default(cuid())
  name                         String
  description                  String?
  websiteUrl                   String?
  logo                         String[]
  bannerImage                  String[]
  colorScheme                  String?
  creatorId                    String
  ownerId                      String
  usesShipping                 Boolean               @default(false)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  employmentNoticeDays         Int                   @default(14)
  orgNumber                    String?               @unique
  orgType                      CompanyOrgType?
  // ─── Company Reach ─────────────────────────────────────────────
  reachLifetime                Float                 @default(0)
  reachMomentum                Float                 @default(0)
  lastMomentumDecay            DateTime?
  employeePulseBonus           Float                 @default(0)
  // ─── Tax Helper ────────────────────────────────────────────────
  taxHelperEnabled             TaxHelperStatus       @default(DISABLED)
  vatRegistered                Boolean               @default(false)
  vatNumber                    String?               @unique
  // ─── Seller Payment Setup ──────────────────────────────────────
  paypalEmail                  String?
  paypalEmailVerifiedAt        DateTime?
  defaultReceivingWalletId     String?
  defaultReceivingWallet       Wallet?               @relation("CompanyDefaultWallet", fields: [defaultReceivingWalletId], references: [id], onDelete: SetNull)

  User_Company_creatorIdToUser User                  @relation("Company_creatorIdToUser", fields: [creatorId], references: [id])
  User_Company_ownerIdToUser   User                  @relation("Company_ownerIdToUser", fields: [ownerId], references: [id])
  Conversation                 Conversation[]
  Employee                     Employee[]
  EmployeeTermination          EmployeeTermination[]
  MonthlyReport                MonthlyReport[]
  Package                      Package[]
  Product                      Product[]
  Sale                         Sale[]
  Wallet                       Wallet[]
  WarehouseLocation            WarehouseLocation[]
  DigitalAsset                 DigitalAsset[]
  TaxReport                    TaxReport[]
  Expense                      Expense[]
  Purchase                     Purchase[]
  TradeRecords                 TradeRecord[]
  orgVerification              CompanyOrgVerification?
}

model CompanyOrgVerification {
  id              String                       @id @default(cuid())
  companyId       String                       @unique
  orgNumber       String
  orgType         CompanyOrgType?
  legalName       String?
  officialEmail   String?
  officialWebsite String?
  officialAddress String?
  status          CompanyOrgVerificationStatus @default(PENDING)
  token           String                       @unique @default(cuid())
  expires         DateTime
  verifiedAt      DateTime?
  deniedAt        DateTime?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  Company         Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([status, expires])
}

model Conversation {
  id                     String                 @id @default(cuid())
  companyId              String?
  title                  String?
  userId                 String
  participants           String[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  allowedRoles           String[]               @default([])
  customViewers          String[]               @default([])
  description            String?
  isLocked               Boolean                @default(false)
  isPinned               Boolean                @default(false)
  replyPermission        ReplyPermission        @default(PARTICIPANTS)
  tags                   String[]               @default([])
  type                   ConversationType       @default(PRIVATE_DM)
  visibility             ConversationVisibility @default(PARTICIPANTS)
  lastActivityAt         DateTime               @default(now())
  replyCount             Int                    @default(0)
  uniqueRepliers         Int                    @default(0)
  viewCount              Int                    @default(0)
  deletionRequestedAt    DateTime?
  deletionScheduledFor   DateTime?
  deletionVisibility     DeletionVisibility     @default(PRIVATE)
  isAnonymized           Boolean                @default(false)
  originalUserId         String?
  suspiciousActivity     Boolean                @default(false)
  suspiciousReason       String?
  uniqueViewCount        Int                    @default(0)
  repostOfConversationId String?
  anonymousViewCount     Int                    @default(0)
  editedAt               DateTime?
  loggedInViewCount      Int                    @default(0)
  negativePulseCount     Int                    @default(0)
  positivePulseCount     Int                    @default(0)
  reachScore             Float                  @default(0)
  // ─── Dual Reach: Lifetime + Momentum ─────────────────────────────
  reachLifetime          Float                  @default(0)
  reachMomentum          Float                  @default(0)
  lastMomentumDecay      DateTime?
  // 7-Pillar breakdown (each 0-100 normalized)
  pillarVisibility       Float                  @default(0)
  pillarEngagement       Float                  @default(0)
  pillarConversion       Float                  @default(0)
  pillarLoyalty          Float                  @default(0)
  pillarGrowth           Float                  @default(0)
  pillarRecall           Float                  @default(0)
  pillarVelocity         Float                  @default(0)
  // Echo propagation  
  echoInbound            Float                  @default(0)
  echoOutbound           Float                  @default(0)
  resonanceMultiplier    Float                  @default(1.0)
  resonanceExpiresAt     DateTime?
  repulseCount           Int                    @default(0)
  uniqueIpCount          Int                    @default(0)
  // Pin to main feed (admin only)
  pinnedToFeed           Boolean                @default(false)
  pinnedToFeedAt         DateTime?
  pinnedToFeedByUserId   String?
  Company                Company?               @relation(fields: [companyId], references: [id])
  Conversation           Conversation?          @relation("ConversationToConversation", fields: [repostOfConversationId], references: [id])
  other_Conversation     Conversation[]         @relation("ConversationToConversation")
  User                   User                   @relation(fields: [userId], references: [id])
  ConversationRepost     ConversationRepost[]
  ConversationView       ConversationView[]
  Message                Message[]
  Poll                   Poll?
  AdvancedPoll           AdvancedPoll?
  Pulse                  Pulse[]
  ProfilePins            ProfilePin[]
  PulseProductLinks      PulseProductLink[]
  ContentFlags           ContentFlag[]
  // Visibility targeting
  visibleToUserIds       String[]               @default([])
  visibleToGroupIds      String[]               @default([])

  @@index([userId])
  @@index([type])
  @@index([visibility])
  @@index([lastActivityAt])
  @@index([deletionScheduledFor])
  @@index([type, visibility, lastActivityAt])
  @@index([pinnedToFeed, pinnedToFeedAt])
}

// ─── Content Flags (Admin moderation / content warnings) ──────────────────────
model ContentFlag {
  id             String          @id @default(cuid())
  conversationId String
  flaggedByUserId String
  type           ContentFlagType
  reason         String?         // Optional free-text reason
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  Conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([flaggedByUserId])
  @@index([conversationId, isActive])
}

enum ContentFlagType {
  DISTURBING_CONTENT
  DEATH_OR_INJURY
  NUDITY
  FLASHING_IMAGES
  VIOLENCE
  HATE_SPEECH
  MISINFORMATION
  SPOILER
  SENSITIVE_TOPIC
  OTHER
}

model ConversationRepost {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

// User can pin any pulse to their own profile
model ProfilePin {
  id             String       @id @default(cuid())
  conversationId String       // The pulse being pinned
  userId         String       // The user who pinned it (to their profile)
  pinnedAt       DateTime     @default(now())
  order          Int          @default(0) // For ordering multiple pins
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId]) // One pin per pulse per profile
  @@index([userId, pinnedAt])
  @@index([conversationId])
}

model ConversationView {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  viewCount      Int          @default(1)
  firstViewedAt  DateTime     @default(now())
  lastViewedAt   DateTime     @default(now())
  ipHash         String?
  isLoggedIn     Boolean      @default(false)
  userAgent      String?
  viewStrength   Float        @default(1.0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([ipHash])
}

model ViewEvent {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  ipHash         String
  userAgent      String?
  viewType       ViewType @default(FIRST_VIEW)
  strength       Float    @default(1.0)
  referrer       String?
  sessionId      String?
  viewedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@index([userId])
  @@index([ipHash])
  @@index([viewedAt])
}

model EmailLoginToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, token])
}

model Employee {
  id          String       @id @default(cuid())
  userId      String
  companyId   String
  role        EmployeeRole
  permissions Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  jobTitle       String?
  Company        Company          @relation(fields: [companyId], references: [id])
  User           User             @relation(fields: [userId], references: [id])
  SalaryPayment  SalaryPayment[]
  WorkHourLog    WorkHourLog[]

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model EmployeeTermination {
  id                                               String            @id @default(cuid())
  companyId                                        String
  employeeUserId                                   String
  initiatedByUserId                                String
  status                                           TerminationStatus @default(REQUESTED)
  reason                                           String
  noticeDays                                       Int
  requestedAt                                      DateTime          @default(now())
  effectiveAt                                      DateTime
  cancelledAt                                      DateTime?
  finalizedAt                                      DateTime?
  metadata                                         Json?
  createdAt                                        DateTime          @default(now())
  updatedAt                                        DateTime          @updatedAt
  Company                                          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User_EmployeeTermination_employeeUserIdToUser    User              @relation("EmployeeTermination_employeeUserIdToUser", fields: [employeeUserId], references: [id], onDelete: Cascade)
  User_EmployeeTermination_initiatedByUserIdToUser User              @relation("EmployeeTermination_initiatedByUserIdToUser", fields: [initiatedByUserId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeUserId])
  @@index([companyId, status])
}

model Inventory {
  id                String            @id @default(cuid())
  quantity          Int
  stock             Int               @default(0)
  warehouseId       String
  productId         String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  version           Int               @default(0)
  Product           Product           @relation(fields: [productId], references: [id])
  WarehouseLocation WarehouseLocation @relation(fields: [warehouseId], references: [id])

  @@unique([id, version])
  @@index([warehouseId])
  @@index([productId])
}

model JobRequest {
  id              String   @id @default(cuid())
  price           Float?
  negotiable      Boolean?
  paymentMethod   String?
  delivery        String?
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  userId          String
  companyIds      String[] @default([])
  descriptions    String[]
  images          String[]
  links           String[]
  docs            String[]
  title           String?
  email           String
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String          @id @default(cuid())
  content        String
  senderId       String
  conversationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  imageUrl       String?
  editedAt       DateTime?
  mentions       String[]        @default([])
  parentId       String?
  heartbeatCount Int             @default(0)
  repostCount    Int             @default(0)
  replyCount     Int             @default(0)
  Conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User            @relation(fields: [senderId], references: [id])
  parent         Message?        @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies        Message[]       @relation("MessageReplies")
  MessagePulse   MessagePulse[]
  MessageRepost  MessageRepost[]

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
  @@index([parentId])
}

/// Heartbeat reaction on an individual vibe (message) within a pulse.
/// One heartbeat per user per message, mirroring the Pulse model for conversations.
model MessagePulse {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

/// Repulse (repost) on an individual vibe (message) within a pulse.
/// One repulse per user per message.
model MessageRepost {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model MonthlyReport {
  id             String   @id @default(cuid())
  companyId      String
  year           Int
  month          Int
  totalSales     Float
  totalProfit    Float
  productSummary Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  Company        Company  @relation(fields: [companyId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  transactionId String?
  commentOrder  String?
  
  // Shipping address
  shippingName       String?
  shippingAddress    String?
  shippingCity       String?
  shippingPostalCode String?
  shippingCountry    String?   @default("NO")
  shippingPhone      String?
  shippingEmail      String?
  shippingMethod     String?   // e.g. "PAKKE_I_POSTKASSEN", "SERVICEPAKKE"
  shippingCost       Float?
  
  // Fulfilment status (separate from payment status)
  fulfilmentStatus     FulfilmentStatus @default(UNFULFILLED)
  fulfilledById        String?          // Employee who shipped the order
  claimedByUserId      String?          // Warehouse worker who claimed for packing
  claimedAt            DateTime?        // When the order was claimed
  shippedAt            DateTime?
  deliveredAt          DateTime?
  
  // Bring shipment tracking (populated after booking)
  trackingNumber       String?
  trackingUrl          String?
  bringConsignmentId   String?
  estimatedDelivery    DateTime?
  shippingServiceName  String?   // Human-readable e.g. "Pakke i postkassen"
  labelUrl             String?          // Bring label PDF URL
  
  User          User        @relation(fields: [userId], references: [id])
  Payment       Payment?
  OrderItem     OrderItem[]
  DownloadToken DownloadToken[]
  ReturnRequest ReturnRequest[]

  @@index([userId])
  @@index([status])
  @@index([fulfilmentStatus])
  @@index([claimedByUserId])
  @@index([createdAt])
  @@index([userId, status])
}

/// Buyer-initiated return/refund request (Norwegian Angrerettloven: 14-day withdrawal).
/// Sellers (company or solo) process these via the return management API.
model ReturnRequest {
  id          String             @id @default(cuid())
  orderId     String
  userId      String             // Buyer who initiated the return
  reason      ReturnReason
  description String?            // Free-text explanation from buyer
  status      ReturnRequestStatus @default(PENDING)
  
  // Seller response
  sellerNote  String?            // Seller note to buyer
  processedBy String?            // UserId of seller/employee who processed
  processedAt DateTime?
  refundAmount Float?            // Amount to refund (may differ from order total)
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  Order       Order              @relation(fields: [orderId], references: [id])
  User        User               @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
  @@index([status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Float    // Price when ordered (prices can change)
  title       String   // Product title at time of order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  Order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Package {
  id                String        @id @default(cuid())
  trackingNumber    String
  companyId         String
  userId            String
  status            PackageStatus
  estimatedDelivery DateTime?
  history           Json
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Company           Company       @relation(fields: [companyId], references: [id])
  User              User          @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, token])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  commentPay      String?

  // On-chain crypto payment data
  chainFamily     ChainFamily?  // EVM or SOLANA
  chainId         Int?          // EVM chain id (1=ETH, 369=PLS, 8453=Base…)
  tokenSymbol     String?       // ETH, PLS, SOL, USDC…
  nativeAmount    String?       // Amount in native token (string to avoid float precision)
  senderAddress   String?       // Wallet that sent the payment
  receiverAddress String?       // Wallet that received the payment
  blockNumber     Int?          // Block the tx was confirmed in
  nokRateAtTime   Float?        // NOK per token at tx time (for Norwegian tax)
  usdRateAtTime   Float?        // USD per token at tx time

  Order           Order         @relation(fields: [orderId], references: [id])

  @@index([chainFamily])
  @@index([senderAddress])
  @@index([receiverAddress])
}

model PaymentWebhookEvent {
  id                String   @id @default(cuid())
  provider          String
  eventType         String?
  deliveryId        String?
  signatureVerified Boolean  @default(false)
  sessionId         String?
  orderId           String?
  paymentId         String?
  paymentStatus     String?
  orderStatus       String?
  httpStatus        Int?
  processingError   String?
  rawPayload        Json?
  headers           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([provider, createdAt])
  @@index([eventType])
  @@index([orderId])
  @@unique([provider, deliveryId])
}

model Poll {
  id             String       @id @default(cuid())
  question       String
  conversationId String       @unique
  creatorId      String
  allowMultiple  Boolean      @default(false)
  isAnonymous    Boolean      @default(false)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  PollOption     PollOption[]

  @@index([creatorId])
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  PollVote  PollVote[]

  @@index([pollId])
}

model PollVote {
  id         String     @id @default(cuid())
  optionId   String
  userId     String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  PollOption PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
  @@index([userId])
}

// Category/Tag system for products - supports multiple tags per product
model Category {
  id          String     @id @default(cuid())
  name        String     // Display name: "Digitale tjenester"
  slug        String     @unique // Normalized for matching: "digitale-tjenester"
  parentId    String?    // Optional parent for sub-categories
  description String?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Self-relation for hierarchical categories
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  // Creator relation
  createdBy   User?      @relation("CategoryCreator", fields: [createdById], references: [id])
  
  // Many-to-many with products
  products    ProductCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([name])
}

// Junction table for Product <-> Category many-to-many
model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model Product {
  id                   String                 @id @default(cuid())
  title                String
  description          String
  category             String                 // Keep for backward compatibility, will be deprecated
  price                Float
  priceCurrency         FiatCurrency           @default(USD)
  acceptedFiatCurrencies FiatCurrency[]        @default([])
  stock                Int
  shipFromPostalId     String
  image                String[]
  specifications       Json?
  features             Json?                  // Product features/highlights (array of {text} or {key,value})
  condition            ProductCondition       @default(NEW)
  userId               String
  companyId            String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  receiverWalletId     String?
  
  // Product type (physical, digital, or hybrid)
  productType          ProductType            @default(PHYSICAL)
  
  // Digital product fields
  digitalAssetId       String?                @unique
  downloadsEnabled     Boolean                @default(true)
  maxDownloads         Int?                   // null = unlimited
  downloadExpiryDays   Int?                   // null = never expires
  
  // Shipping options
  freeShippingEnabled  Boolean                @default(false)
  freeShippingThreshold Float?               // null = no threshold (always free if enabled)
  
  // ─── Product Reach ─────────────────────────────────────────────
  reachLifetime        Float                  @default(0)
  reachMomentum        Float                  @default(0)
  lastMomentumDecay    DateTime?
  viewCount            Int                    @default(0)
  uniqueViewCount      Int                    @default(0)
  pulseViewEcho        Float                  @default(0)

  CartItem             CartItem[]
  Inventory            Inventory[]
  Company              Company?               @relation(fields: [companyId], references: [id])
  Wallet               Wallet?                @relation(fields: [receiverWalletId], references: [id])
  User                 User                   @relation(fields: [userId], references: [id])
  ProductAcceptedToken ProductAcceptedToken[]
  Review               Review[]
  ShippingDetails      ShippingDetails[]
  OrderItem            OrderItem[]
  DigitalAsset         DigitalAsset?          @relation(fields: [digitalAssetId], references: [id])
  PulseProductLinks    PulseProductLink[]
  
  // New many-to-many categories/tags
  categories           ProductCategory[]

  @@index([category])
  @@index([price])
  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
  @@index([category, price])
  @@index([productType])
  @@index([reachMomentum])
}

// Digital asset storage for downloadable products
model DigitalAsset {
  id              String           @id @default(cuid())
  
  // File metadata
  fileName        String           // Original filename
  fileSize        Int              // Size in bytes
  mimeType        String           // e.g., "application/zip", "image/jpeg"
  fileExtension   String           // e.g., "zip", "jpg", "rar"
  
  // Storage (encrypted)
  storageKey      String           @unique  // Key/path in storage provider
  storageProvider StorageProvider  @default(EDGESTORE)
  encryptionKey   String?          // Encrypted with server key
  checksum        String           // SHA-256 hash for integrity
  
  // Ownership
  uploadedById    String
  companyId       String?
  
  // Status
  isActive        Boolean          @default(true)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  User            User             @relation(fields: [uploadedById], references: [id])
  Company         Company?         @relation(fields: [companyId], references: [id])
  Product         Product?
  DownloadToken   DownloadToken[]

  @@index([uploadedById])
  @@index([companyId])
  @@index([storageKey])
}

// Secure download tokens - generated after purchase
model DownloadToken {
  id              String          @id @default(cuid())
  
  // Token info
  token           String          @unique  // Secure random token
  
  // Links
  digitalAssetId  String
  orderId         String
  orderItemId     String?
  userId          String
  
  // Limits
  maxUses         Int             @default(5)
  usedCount       Int             @default(0)
  expiresAt       DateTime?       // null = never expires
  
  // Tracking
  lastUsedAt      DateTime?
  lastUsedIp      String?
  userAgent       String?
  
  // Status
  isRevoked       Boolean         @default(false)
  revokedReason   String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  DigitalAsset    DigitalAsset    @relation(fields: [digitalAssetId], references: [id])
  Order           Order           @relation(fields: [orderId], references: [id])
  User            User            @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([digitalAssetId])
  @@index([orderId])
  @@index([userId])
  @@index([expiresAt])
}

model ProductAcceptedToken {
  id           String      @id @default(cuid())
  productId    String
  family       ChainFamily
  tokenAddress String?
  tokenMint    String?
  symbol       String
  decimals     Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Product      Product     @relation(fields: [productId], references: [id])

  @@unique([productId, family, symbol])
}

model Review {
