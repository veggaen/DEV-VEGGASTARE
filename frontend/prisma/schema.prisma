generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  User      User       @relation(fields: [userId], references: [id])
  CartItem  CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Cart      Cart     @relation(fields: [cartId], references: [id])
  Product   Product  @relation(fields: [productId], references: [id])

  @@unique([productId, cartId])
}

model Company {
  id                           String                @id @default(cuid())
  name                         String
  description                  String?
  websiteUrl                   String?
  logo                         String[]
  bannerImage                  String[]
  colorScheme                  String?
  creatorId                    String
  ownerId                      String
  usesShipping                 Boolean               @default(false)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  employmentNoticeDays         Int                   @default(14)
  orgNumber                    String?               @unique
  orgType                      CompanyOrgType?
  User_Company_creatorIdToUser User                  @relation("Company_creatorIdToUser", fields: [creatorId], references: [id])
  User_Company_ownerIdToUser   User                  @relation("Company_ownerIdToUser", fields: [ownerId], references: [id])
  Conversation                 Conversation[]
  Employee                     Employee[]
  EmployeeTermination          EmployeeTermination[]
  MonthlyReport                MonthlyReport[]
  Package                      Package[]
  Product                      Product[]
  Sale                         Sale[]
  Wallet                       Wallet[]
  WarehouseLocation            WarehouseLocation[]
  DigitalAsset                 DigitalAsset[]
}

model Conversation {
  id                     String                 @id @default(cuid())
  companyId              String?
  title                  String?
  userId                 String
  participants           String[]
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  allowedRoles           String[]               @default([])
  customViewers          String[]               @default([])
  description            String?
  isLocked               Boolean                @default(false)
  isPinned               Boolean                @default(false)
  replyPermission        ReplyPermission        @default(PARTICIPANTS)
  tags                   String[]               @default([])
  type                   ConversationType       @default(PRIVATE_DM)
  visibility             ConversationVisibility @default(PARTICIPANTS)
  lastActivityAt         DateTime               @default(now())
  replyCount             Int                    @default(0)
  uniqueRepliers         Int                    @default(0)
  viewCount              Int                    @default(0)
  deletionRequestedAt    DateTime?
  deletionScheduledFor   DateTime?
  deletionVisibility     DeletionVisibility     @default(PRIVATE)
  isAnonymized           Boolean                @default(false)
  originalUserId         String?
  suspiciousActivity     Boolean                @default(false)
  suspiciousReason       String?
  uniqueViewCount        Int                    @default(0)
  repostOfConversationId String?
  anonymousViewCount     Int                    @default(0)
  editedAt               DateTime?
  loggedInViewCount      Int                    @default(0)
  negativePulseCount     Int                    @default(0)
  positivePulseCount     Int                    @default(0)
  reachScore             Float                  @default(0)
  repulseCount           Int                    @default(0)
  uniqueIpCount          Int                    @default(0)
  Company                Company?               @relation(fields: [companyId], references: [id])
  Conversation           Conversation?          @relation("ConversationToConversation", fields: [repostOfConversationId], references: [id])
  other_Conversation     Conversation[]         @relation("ConversationToConversation")
  User                   User                   @relation(fields: [userId], references: [id])
  ConversationRepost     ConversationRepost[]
  ConversationView       ConversationView[]
  Message                Message[]
  Poll                   Poll?
  AdvancedPoll           AdvancedPoll?
  Pulse                  Pulse[]

  @@index([userId])
  @@index([type])
  @@index([visibility])
  @@index([lastActivityAt])
  @@index([deletionScheduledFor])
  @@index([type, visibility, lastActivityAt])
}

model ConversationRepost {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  createdAt      DateTime     @default(now())
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model ConversationView {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  viewCount      Int          @default(1)
  firstViewedAt  DateTime     @default(now())
  lastViewedAt   DateTime     @default(now())
  ipHash         String?
  isLoggedIn     Boolean      @default(false)
  userAgent      String?
  viewStrength   Float        @default(1.0)
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([ipHash])
}

model ViewEvent {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  ipHash         String
  userAgent      String?
  viewType       ViewType @default(FIRST_VIEW)
  strength       Float    @default(1.0)
  referrer       String?
  sessionId      String?
  viewedAt       DateTime @default(now())

  @@index([conversationId])
  @@index([userId])
  @@index([ipHash])
  @@index([viewedAt])
}

model EmailLoginToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Employee {
  id          String       @id @default(cuid())
  userId      String
  companyId   String
  role        EmployeeRole
  permissions Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  jobTitle    String?
  Company     Company      @relation(fields: [companyId], references: [id])
  User        User         @relation(fields: [userId], references: [id])

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

model EmployeeTermination {
  id                                               String            @id @default(cuid())
  companyId                                        String
  employeeUserId                                   String
  initiatedByUserId                                String
  status                                           TerminationStatus @default(REQUESTED)
  reason                                           String
  noticeDays                                       Int
  requestedAt                                      DateTime          @default(now())
  effectiveAt                                      DateTime
  cancelledAt                                      DateTime?
  finalizedAt                                      DateTime?
  metadata                                         Json?
  Company                                          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  User_EmployeeTermination_employeeUserIdToUser    User              @relation("EmployeeTermination_employeeUserIdToUser", fields: [employeeUserId], references: [id], onDelete: Cascade)
  User_EmployeeTermination_initiatedByUserIdToUser User              @relation("EmployeeTermination_initiatedByUserIdToUser", fields: [initiatedByUserId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeUserId])
  @@index([companyId, status])
}

model Inventory {
  id                String            @id @default(cuid())
  quantity          Int
  stock             Int               @default(0)
  warehouseId       String
  productId         String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  version           Int               @default(0)
  Product           Product           @relation(fields: [productId], references: [id])
  WarehouseLocation WarehouseLocation @relation(fields: [warehouseId], references: [id])

  @@unique([id, version])
}

model JobRequest {
  id              String   @id @default(cuid())
  price           Float?
  negotiable      Boolean?
  paymentMethod   String?
  delivery        String?
  additionalNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now())
  userId          String
  companyIds      String[] @default([])
  descriptions    String[]
  images          String[]
  links           String[]
  docs            String[]
  title           String?
  email           String
  User            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  conversationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  imageUrl       String?
  editedAt       DateTime?
  mentions       String[]     @default([])
  parentId       String?
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, createdAt])
}

model MonthlyReport {
  id             String   @id @default(cuid())
  companyId      String
  year           Int
  month          Int
  totalSales     Float
  totalProfit    Float
  productSummary Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  Company        Company  @relation(fields: [companyId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  transactionId String?
  commentOrder  String?
  
  // Shipping address
  shippingName       String?
  shippingAddress    String?
  shippingCity       String?
  shippingPostalCode String?
  shippingCountry    String?   @default("NO")
  shippingPhone      String?
  shippingEmail      String?
  shippingMethod     String?   // e.g. "PAKKE_I_POSTKASSEN", "SERVICEPAKKE"
  shippingCost       Float?
  
  User          User        @relation(fields: [userId], references: [id])
  Payment       Payment?
  OrderItem     OrderItem[]
  DownloadToken DownloadToken[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  priceAtTime Float    // Price when ordered (prices can change)
  title       String   // Product title at time of order
  createdAt   DateTime @default(now())
  
  Order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Package {
  id                String        @id @default(cuid())
  trackingNumber    String
  companyId         String
  userId            String
  status            PackageStatus
  estimatedDelivery DateTime?
  history           Json
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Company           Company       @relation(fields: [companyId], references: [id])
  User              User          @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  commentPay    String?
  Order         Order         @relation(fields: [orderId], references: [id])
}

model Poll {
  id             String       @id @default(cuid())
  question       String
  conversationId String       @unique
  creatorId      String
  allowMultiple  Boolean      @default(false)
  isAnonymous    Boolean      @default(false)
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  PollOption     PollOption[]
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  text      String
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  Poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  PollVote  PollVote[]
}

model PollVote {
  id         String     @id @default(cuid())
  optionId   String
  userId     String
  createdAt  DateTime   @default(now())
  PollOption PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, userId])
}

// Category/Tag system for products - supports multiple tags per product
model Category {
  id          String     @id @default(cuid())
  name        String     // Display name: "Digitale tjenester"
  slug        String     @unique // Normalized for matching: "digitale-tjenester"
  parentId    String?    // Optional parent for sub-categories
  description String?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Self-relation for hierarchical categories
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  // Creator relation
  createdBy   User?      @relation("CategoryCreator", fields: [createdById], references: [id])
  
  // Many-to-many with products
  products    ProductCategory[]

  @@index([slug])
  @@index([parentId])
  @@index([name])
}

// Junction table for Product <-> Category many-to-many
model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
}

model Product {
  id                   String                 @id @default(cuid())
  title                String
  description          String
  category             String                 // Keep for backward compatibility, will be deprecated
  price                Float
  priceCurrency         FiatCurrency           @default(USD)
  acceptedFiatCurrencies FiatCurrency[]        @default([])
  stock                Int
  shipFromPostalId     String
  image                String[]
  specifications       Json?
  condition            ProductCondition       @default(NEW)
  userId               String
  companyId            String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  receiverWalletId     String?
  
  // Product type (physical, digital, or hybrid)
  productType          ProductType            @default(PHYSICAL)
  
  // Digital product fields
  digitalAssetId       String?                @unique
  downloadsEnabled     Boolean                @default(true)
  maxDownloads         Int?                   // null = unlimited
  downloadExpiryDays   Int?                   // null = never expires
  
  // Shipping options
  freeShippingEnabled  Boolean                @default(false)
  freeShippingThreshold Float?               // null = no threshold (always free if enabled)
  
  CartItem             CartItem[]
  Inventory            Inventory[]
  Company              Company?               @relation(fields: [companyId], references: [id])
  Wallet               Wallet?                @relation(fields: [receiverWalletId], references: [id])
  User                 User                   @relation(fields: [userId], references: [id])
  ProductAcceptedToken ProductAcceptedToken[]
  Review               Review[]
  ShippingDetails      ShippingDetails[]
  OrderItem            OrderItem[]
  DigitalAsset         DigitalAsset?          @relation(fields: [digitalAssetId], references: [id])
  
  // New many-to-many categories/tags
  categories           ProductCategory[]

  @@index([category])
  @@index([price])
  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
  @@index([category, price])
  @@index([productType])
}

// Digital asset storage for downloadable products
model DigitalAsset {
  id              String           @id @default(cuid())
  
  // File metadata
  fileName        String           // Original filename
  fileSize        Int              // Size in bytes
  mimeType        String           // e.g., "application/zip", "image/jpeg"
  fileExtension   String           // e.g., "zip", "jpg", "rar"
  
  // Storage (encrypted)
  storageKey      String           @unique  // Key/path in storage provider
  storageProvider StorageProvider  @default(EDGESTORE)
  encryptionKey   String?          // Encrypted with server key
  checksum        String           // SHA-256 hash for integrity
  
  // Ownership
  uploadedById    String
  companyId       String?
  
  // Status
  isActive        Boolean          @default(true)
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  User            User             @relation(fields: [uploadedById], references: [id])
  Company         Company?         @relation(fields: [companyId], references: [id])
  Product         Product?
  DownloadToken   DownloadToken[]

  @@index([uploadedById])
  @@index([companyId])
  @@index([storageKey])
}

// Secure download tokens - generated after purchase
model DownloadToken {
  id              String          @id @default(cuid())
  
  // Token info
  token           String          @unique  // Secure random token
  
  // Links
  digitalAssetId  String
  orderId         String
  orderItemId     String?
  userId          String
  
  // Limits
  maxUses         Int             @default(5)
  usedCount       Int             @default(0)
  expiresAt       DateTime?       // null = never expires
  
  // Tracking
  lastUsedAt      DateTime?
  lastUsedIp      String?
  userAgent       String?
  
  // Status
  isRevoked       Boolean         @default(false)
  revokedReason   String?
  
  createdAt       DateTime        @default(now())
  
  DigitalAsset    DigitalAsset    @relation(fields: [digitalAssetId], references: [id])
  Order           Order           @relation(fields: [orderId], references: [id])
  User            User            @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([digitalAssetId])
  @@index([orderId])
  @@index([userId])
  @@index([expiresAt])
}

model ProductAcceptedToken {
  id           String      @id @default(cuid())
  productId    String
  family       ChainFamily
  tokenAddress String?
  tokenMint    String?
  symbol       String
  decimals     Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Product      Product     @relation(fields: [productId], references: [id])

  @@unique([productId, family, symbol])
}

model Review {
  id         String   @id @default(cuid())
  authorName String?
  rating     Float
  comment    String
  productId  String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  Product    Product  @relation(fields: [productId], references: [id])
  User       User     @relation(fields: [userId], references: [id])
}

model Sale {
  id           String   @id @default(cuid())
  companyId    String
  date         DateTime
  totalAmount  Float
  profit       Float
  productsSold Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  Company      Company  @relation(fields: [companyId], references: [id])
}

model SecurityActionToken {
  id        String             @id @default(cuid())
  userId    String
  email     String
  token     String             @unique
  action    SecurityActionType
  expires   DateTime
  createdAt DateTime           @default(now())
  User      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, action])
  @@index([userId, action])
}

model ShippingDetails {
  id        String   @id @default(cuid())
  method    String
  price     Float
  regions   String[]
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Product   Product  @relation(fields: [productId], references: [id])
}

model SpecificationsDetails {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique
  User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

// Admin audit log for tracking all admin actions
model AdminAuditLog {
  id            String          @id @default(cuid())
  adminId       String          // The admin who performed the action
  action        AdminAction     // Type of action performed
  targetType    AdminTargetType // What type of entity was affected
  targetId      String          // ID of the affected entity
  previousData  Json?           // Previous state (for edits)
  newData       Json?           // New state (for edits)
  ipAddress     String?         // IP address of the admin
  userAgent     String?         // Browser/client info
  reason        String?         // Optional reason for the action
  createdAt     DateTime        @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([action])
  @@index([createdAt])
}

model User {
  id                                                              String                        @id @default(cuid())
  name                                                            String?
  email                                                           String?                       @unique
  emailVerified                                                   DateTime?
  image                                                           String?
  password                                                        String?
  referredBy                                                      String?
  role                                                            UserRole                      @default(USER)
  isTwoFactorEnabled                                              Boolean                       @default(false)
  createdAt                                                       DateTime                      @default(now())
  updatedAt                                                       DateTime                      @updatedAt
  web3ModeEnabled                                                 Boolean                       @default(false)
  banner                                                          String?
  bio                                                             String?
  hasDiscordAuth                                                  Boolean                       @default(false)
  hasGithubAuth                                                   Boolean                       @default(false)
  hasGoogleAuth                                                   Boolean                       @default(false)
  hasVerifiedWallet                                               Boolean                       @default(false)
  hasWeb2Payment                                                  Boolean                       @default(false)
  hasWeb3Payment                                                  Boolean                       @default(false)
  phoneCountryCode                                                String?
  phoneNumber                                                     String?                       @unique
  phoneVerified                                                   DateTime?
  siteNoticeDismissedVersion                                      Int                           @default(0)
  verificationScore                                               Int                           @default(0)
  verificationTier                                                UserVerificationTier          @default(ANONYMOUS)
  Account                                                         Account[]
  Cart                                                            Cart?
  Company_Company_creatorIdToUser                                 Company[]                     @relation("Company_creatorIdToUser")
  Company_Company_ownerIdToUser                                   Company[]                     @relation("Company_ownerIdToUser")
  Conversation                                                    Conversation[]
  ConversationRepost                                              ConversationRepost[]
  ConversationView                                                ConversationView[]
  Employee                                                        Employee[]
  EmployeeTermination_EmployeeTermination_employeeUserIdToUser    EmployeeTermination[]         @relation("EmployeeTermination_employeeUserIdToUser")
  EmployeeTermination_EmployeeTermination_initiatedByUserIdToUser EmployeeTermination[]         @relation("EmployeeTermination_initiatedByUserIdToUser")
  followers                                                       Follow[]                      @relation("UserFollowers")
  following                                                       Follow[]                      @relation("UserFollowing")
  receivedFriendRequests                                          FriendRequest[]               @relation("ReceivedFriendRequests")
  sentFriendRequests                                              FriendRequest[]               @relation("SentFriendRequests")
  friendshipsA                                                    Friendship[]                  @relation("FriendshipsA")
  friendshipsB                                                    Friendship[]                  @relation("FriendshipsB")
  JobRequest                                                      JobRequest[]
  Message                                                         Message[]
  Order                                                           Order[]
  Package                                                         Package[]
  PhoneVerification                                               PhoneVerification[]
  Product                                                         Product[]
  pulses                                                          Pulse[]
  Review                                                          Review[]
  SecurityActionToken                                             SecurityActionToken[]
  TwoFactorConfirmation                                           TwoFactorConfirmation?
  privacySettings                                                 UserPrivacySettings?
  Wallet                                                          Wallet[]
  WalletVerificationChallenge                                     WalletVerificationChallenge[]
  WarehouseLocation                                               WarehouseLocation[]
  DigitalAsset                                                    DigitalAsset[]
  DownloadToken                                                   DownloadToken[]
  CategoriesCreated                                               Category[]                    @relation("CategoryCreator")
  Address                                                         Address[]
  // Advanced Poll System relations
  AdvancedPolls                                                   AdvancedPoll[]
  PollResponses                                                   PollResponse[]
  PollTemplates                                                   PollTemplate[]
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Wallet {
  id             String      @id @default(cuid())
  label          String
  family         ChainFamily
  chainId        Int?
  solanaCluster  String?
  address        String
  isDefault      Boolean     @default(false)
  ownerUserId    String?
  ownerCompanyId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  verifiedAt     DateTime?
  Product        Product[]
  Company        Company?    @relation(fields: [ownerCompanyId], references: [id])
  User           User?       @relation(fields: [ownerUserId], references: [id])
}

model WalletVerificationChallenge {
  id            String      @id @default(cuid())
  userId        String
  family        ChainFamily
  address       String
  chainId       Int?
  solanaCluster String?
  nonce         String
  message       String
  expires       DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
  User          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expires])
  @@index([userId, family, address])
}

model WarehouseLocation {
  id           String      @id @default(cuid())
  userId       String?
  companyId    String?
  postalCode   String
  address      String
  addressLine2 String?
  city         String
  country      String
  latitude     Float?
  longitude    Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Inventory    Inventory[]
  Company      Company?    @relation(fields: [companyId], references: [id])
  User         User?       @relation(fields: [userId], references: [id])

  @@unique([companyId, postalCode])
}

// User saved addresses (home, work, etc.)
model Address {
  id           String       @id @default(cuid())
  userId       String
  label        AddressLabel @default(OTHER)
  customLabel  String?      // For "OTHER" type - user can name it
  addressLine1 String       // Street address + number
  addressLine2 String?      // Apartment, suite, unit, etc.
  postalCode   String
  city         String
  municipality String?
  county       String?
  country      String       @default("NO")
  latitude     Float?
  longitude    Float?
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model FriendRequest {
  id         String              @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  receiver   User                @relation("ReceivedFriendRequests", fields: [receiverId], references: [id], onDelete: Cascade)
  sender     User                @relation("SentFriendRequests", fields: [senderId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([receiverId, status])
}

model Friendship {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime @default(now())
  userA     User     @relation("FriendshipsA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User     @relation("FriendshipsB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Pulse {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  type           PulseType
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([type])
}

model PhoneVerification {
  id          String                    @id @default(cuid())
  userId      String
  phoneNumber String
  countryCode String
  provider    PhoneVerificationProvider @default(SVEVE)
  code        String?
  attempts    Int                       @default(0)
  status      PhoneVerificationStatus   @default(PENDING)
  expiresAt   DateTime
  verifiedAt  DateTime?
  lastSentAt  DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  User        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@index([status])
}

model UserPrivacySettings {
  id                  String   @id @default(cuid())
  userId              String   @unique
  showPulsesGiven     Boolean  @default(true)
  showPulsesReceived  Boolean  @default(true)
  showNegativePulses  Boolean  @default(false)
  showRepulses        Boolean  @default(true)
  allowNegativePulses Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  User                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id             String              @id @default(cuid())
  userId         String              // Recipient
  type           NotificationType
  title          String
  message        String
  emoji          String?
  preview        String?             // Short preview text
  imageUrl       String?             // Optional image thumbnail
  
  // Related entities
  actorId        String?             // User who triggered the notification
  conversationId String?             // Related pulse/conversation
  messageId      String?             // Related message
  
  // State
  isRead         Boolean             @default(false)
  isArchived     Boolean             @default(false)
  readAt         DateTime?
  
  // Grouping (for condensed notifications)
  groupKey       String?             // e.g., "heartbeat:conversationId" for grouping
  groupCount     Int                 @default(1)
  
  // Metadata
  metadata       Json?               // Extra data like { bpm: 100 } for hot pulse
  
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  expiresAt      DateTime?           // Optional expiry for ephemeral notifications
  
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([groupKey])
}

model NotificationSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  
  // Global settings
  pushEnabled             Boolean  @default(true)
  emailEnabled            Boolean  @default(false)
  soundEnabled            Boolean  @default(true)
  vibrateEnabled          Boolean  @default(true)
  
  // Quiet hours
  quietHoursEnabled       Boolean  @default(false)
  quietHoursStart         String?  // e.g., "22:00"
  quietHoursEnd           String?  // e.g., "08:00"
  quietHoursTimezone      String?  @default("UTC")
  
  // Category toggles (engagement)
  heartbeatEnabled        Boolean  @default(true)
  vibeEnabled             Boolean  @default(true)
  repulseEnabled          Boolean  @default(true)
  
  // Category toggles (social)
  syncEnabled             Boolean  @default(true)
  mentionEnabled          Boolean  @default(true)
  replyEnabled            Boolean  @default(true)
  
  // Category toggles (messages)
  dmEnabled               Boolean  @default(true)
  groupMessageEnabled     Boolean  @default(true)
  typingIndicatorEnabled  Boolean  @default(true)
  
  // Category toggles (trends)
  hotPulseEnabled         Boolean  @default(true)
  milestoneEnabled        Boolean  @default(true)
  
  // Category toggles (prompts)
  vibeCheckEnabled        Boolean  @default(false)
  dailyDigestEnabled      Boolean  @default(false)
  
  // Condensing settings
  condenseNotifications   Boolean  @default(true)
  condenseThreshold       Int      @default(3) // Group after X similar notifications
  
  // Premium features
  customSoundUrl          String?
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  @@index([userId])
}

model NotificationMute {
  id           String         @id @default(cuid())
  userId       String         // User who muted
  
  // What's being muted (one of these will be set)
  mutedUserId  String?        // Mute notifications from specific user
  conversationId String?      // Mute specific conversation/pulse
  companyId    String?        // Mute company-related notifications
  
  // Mute settings
  muteType     MuteType       @default(ALL)
  reason       String?
  
  // Duration
  mutedAt      DateTime       @default(now())
  expiresAt    DateTime?      // null = permanent, otherwise temporary
  
  @@unique([userId, mutedUserId])
  @@unique([userId, conversationId])
  @@unique([userId, companyId])
  @@index([userId])
  @@index([expiresAt])
}

model UserPresence {
  id            String         @id @default(cuid())
  userId        String         @unique
  status        PresenceStatus @default(OFFLINE)
  customStatus  String?        // e.g., "Out rippling IRL"
  lastSeen      DateTime       @default(now())
  lastActiveAt  DateTime       @default(now())
  
  // Current activity
  currentActivity String?      // e.g., "Browsing Pulses", "In conversation"
  
  @@index([status])
  @@index([lastSeen])
}

