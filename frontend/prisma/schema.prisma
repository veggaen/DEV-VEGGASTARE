// ─── Reach 7-Pillar System: New Models ─────────────────────────────────────────
// ═══════════════════════════════════════════════════════════════════════════════

/// Engagement events — the structured ledger for all non-view interactions.
/// Feeds into Pillar 2 (Engagement Depth), Pillar 4 (Loyalty), Pillar 6 (Recall).
model EngagementEvent {
  id              String           @id @default(cuid())
  conversationId  String?          // Pulse context
  productId       String?          // Product context
  companyId       String?          // Company context
  userId          String?          // Who performed the action (null = anonymous)
  ipHash          String?
  sessionId       String?          // Anonymous session hash

  eventType       EngagementType   // What happened
  strength        Float            @default(0)   // Calculated strength
  details         Json?            // {element, durationMs, scrollDepth, hoverTarget, ...}
  referrer        String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([conversationId, createdAt])
  @@index([productId, createdAt])
  @@index([userId, createdAt])
  @@index([eventType])
  @@index([sessionId])
}

enum EngagementType {
  // Pillar 2: Engagement Depth
  CLICK               // Click on element (comment, link, image)
  HOVER_DEEP_READ     // Hover >3s over content section
  SCROLL_DEPTH        // Scroll >75% of content  
  DWELL_TIME          // Active time on page (tab focused)
  SAVE_BOOKMARK       // Save/bookmark content
  COPY_TEXT           // Copy text from content
  COMMENT_SHORT       // Short vibe/comment (<50 chars)
  COMMENT_LONG        // Substantive comment (>50 chars)
  COMMENT_THREAD      // Reply in a thread (depth >1)
  HEARTBEAT           // Pulse/like on a vibe
  REPULSE             // Repost/repulse 
  SHARE_EXTERNAL      // Share to external platform
  
  // Pillar 3: Conversion Impact
  PRODUCT_VIEW        // Viewed a product page
  PRODUCT_CLICK       // Clicked product from pulse
  ADD_TO_CART         // Added item to cart
  PURCHASE            // Completed purchase
  PROFILE_FOLLOW      // Followed a user from content
  
  // Pillar 6: Recall (return signals)
  RETURN_VISIT        // Revisited after >1h
  TAB_REFOCUS         // Returned to tab after switching away
}

/// Echo propagation edges — tracks how reach flows through repulse chains.
/// The "Origin Echo" mechanic: when B repulses A's pulse, and C views B's repulse,
/// 15-30% of that view strength flows back to A's original pulse.
model EchoEdge {
  id               String   @id @default(cuid())
  parentPulseId    String   // Original pulse receiving echo credit
  childPulseId     String   // Repulse/child that generated the echo
  depth            Int      @default(1)   // 1 = direct child, 2 = grandchild, etc.
  echoStrength     Float    @default(0)   // Accumulated echo credit flowing to parent
  uniqueEngagers   Int      @default(0)   // Unique people on child (anti-gaming: need >3)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([parentPulseId, childPulseId])
  @@index([parentPulseId])
  @@index([childPulseId])
}

/// Links between pulses and products (shoppable embeds).
/// When a pulse mentions/embeds a product, interactions flow between them.
model PulseProductLink {
  id             String       @id @default(cuid())
  conversationId String
  productId      String
  weight         Float        @default(1.0) // Prominence weight
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  Conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  Product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([conversationId, productId])
  @@index([conversationId])
  @@index([productId])
}

/// Daily rollup for fast analytics and pillar computation.
/// Aggregated by cron; prevents heavy queries on raw event tables.
model DailyReachRollup {
  id              String   @id @default(cuid())
  conversationId  String?
  productId       String?
  companyId       String?
  userId          String?  // For user-level aggregation
  date            DateTime @db.Date

  // Pillar deltas for the day
  dVisibility     Float    @default(0) // Delta visibility
  dEngagement     Float    @default(0) // Delta engagement depth
  dConversion     Float    @default(0) // Delta conversion impact
  dLoyalty        Float    @default(0) // Delta loyalty
  dGrowth         Float    @default(0) // Delta growth
  dRecall         Float    @default(0) // Delta recall
  dVelocity       Float    @default(0) // Delta velocity

  // Aggregates
  totalViews      Int      @default(0)
  uniqueViewers   Int      @default(0)
  totalEngagements Int     @default(0)
  uniqueEngagers  Int      @default(0)
  echoIn          Float    @default(0)
  echoOut         Float    @default(0)
  addedLifetime   Float    @default(0)
  addedMomentum   Float    @default(0)
  breadthRatio    Float    @default(0) // unique/total for anti-gaming

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([conversationId, date])
  @@unique([productId, date])
  @@unique([companyId, date])
  @@unique([userId, date])
  @@index([date])
  @@index([conversationId])
  @@index([userId])
}

