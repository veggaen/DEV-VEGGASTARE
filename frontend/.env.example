# Frontend environment template (safe to commit — NO real secrets)
# Copy to `.env.local` for local development:
#   cp .env.example .env.local
# Then fill in the blank values with your actual credentials.

# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Only needed for local dev; Vercel uses its own DB env var (set in dashboard).
DATABASE_URL_MAINDEV=
DATABASE_URL_MAINPREVIEW=
DATABASE_URL_MAINLIVE=

# ─── Auth (NextAuth / Auth.js) ──────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GOOGLE_API_KEY=
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ─── Core App ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3002
NEXT_PUBLIC_APPKIT_PROJECT_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── File Storage (EdgeStore) ───────────────────────────────────────────────
EDGE_STORE_ACCESS_KEY=
EDGE_STORE_SECRET_KEY=

# ─── Bring API (address/checkout/shipping) ──────────────────────────────────
BRING_SHIPPING_API_KEY=
BRING_SHIPPING_API_UID=
BRING_CUSTOMER_NUMBER=
Bring_Client_URL=veggat.com
NEXT_PUBLIC_TEST_MODE=true
BRING_TEST_MODE=true

# ─── Maps ────────────────────────────────────────────────────────────────────
MAPS_API_KEY=

# ─── Unsplash ────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=
UNSPLASH_ID=

# ─── PayPal (frontend API routes) ───────────────────────────────────────────
# Sandbox in local/dev; production values in Vercel Production env.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_API_URL=https://api-m.sandbox.paypal.com
PAYPAL_WEBHOOK_URL=https://veggat.com/api/payments/webhook/paypal
PAYPAL_WEBHOOK_EVENTS=CHECKOUT.ORDER.APPROVED,CHECKOUT.ORDER.COMPLETED,CHECKOUT.ORDER.VOIDED,CHECKOUT.ORDER.DECLINED

# ─── Crypto / Web3 ──────────────────────────────────────────────────────────
COINMARKETCAP_API_KEY=
NEXT_PUBLIC_ETHEREUM_RPC=
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
NEXT_PUBLIC_SOL_MAINNET_RPC=
NEXT_PUBLIC_SOL_DEVNET_RPC=
NEXT_PUBLIC_SEPOLIA_RPC=
HELIUS_API_KEY=

# ─── Local Blockchains (development only) ───────────────────────────────────
NEXT_PUBLIC_ENABLE_LOCAL_CHAINS=true
NEXT_PUBLIC_ANVIL_RPC_URL=http://127.0.0.1:8545
NEXT_PUBLIC_GANACHE_RPC_URL=http://127.0.0.1:7545

# ─── DEX / Swap Aggregation (KyberSwap — no API key required) ────────────────
# KYBER_SWAP_FEE_BPS=25      # optional integrator fee (basis points)
# KYBER_SWAP_FEE_RECEIVER=   # fee receiver wallet address
# COINGECKO_API_KEY=          # optional — improves free-tier rate limits

# ─── Paper Trading (Phase 2 — on-chain simulation) ──────────────────────────
# TENDERLY_API_KEY=
# TENDERLY_ACCOUNT=
# TENDERLY_PROJECT=

# ─── Realtime (Pusher) ──────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ─── AI / LLM ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=
BYOK_ENCRYPTION_KEY=
PLATFORM_OWNER_EMAIL=
AI_PAID_PRODUCT_IDS=
AI_PAID_DEFAULT_DAILY_LIMIT=50
AI_PAID_PRODUCT_DAILY_LIMITS=
AI_PAID_CREDIT_PACK_PRODUCTS=

# ─── Access Gate ─────────────────────────────────────────────────────────────
GATE_STATUS=true
GATE_PASSWORD=
ACCESS_GATE_COOKIE_DOMAIN=.veggat.com

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@localhost:6379

# ─── GitHub Webhook ──────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# ─── CSP (opt-in, leave commented for dev) ───────────────────────────────────
# CSP_ENFORCE=true
# CSP_REPORT=true

# ─── Runtime toggles (optional) ─────────────────────────────────────────────
# PAYMENTS_LIVE_ENABLED=false
# BRING_LIVE_ENABLED=false
